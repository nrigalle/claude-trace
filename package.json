{
  "name": "claude-trace",
  "displayName": "Claude Trace: Cost, Sessions & Agent Workflows for Claude Code",
  "version": "1.7.0",
  "description": "Cost dashboard, multi-session terminal cockpit, visual agent workflows, and a skills and agents library for Claude Code. Track spend, run many sessions at once, orchestrate agents on your subscription, and manage every skill and agent in one place. Nothing leaves your machine.",
  "publisher": "nrigalle",
  "license": "MIT",
  "author": {
    "name": "Nathan Rigalle"
  },
  "homepage": "https://github.com/nrigalle/claude-trace#readme",
  "bugs": {
    "url": "https://github.com/nrigalle/claude-trace/issues"
  },
  "qna": "marketplace",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrigalle/claude-trace.git"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude code",
    "claude",
    "cost",
    "usage",
    "tokens",
    "token usage",
    "dashboard",
    "cost tracking",
    "usage monitor",
    "multi-session",
    "terminal",
    "cockpit",
    "subagents",
    "agent teams",
    "multi-agent",
    "orchestration",
    "workflows",
    "anthropic",
    "cli",
    "spend",
    "budget",
    "context window",
    "observability"
  ],
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/nrigalle.claude-trace.svg?label=VS%20Marketplace",
      "href": "https://marketplace.visualstudio.com/items?itemName=nrigalle.claude-trace",
      "description": "VS Code Marketplace Version"
    }
  ],
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:claudeTrace.dashboard"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeTrace.openDashboard",
        "title": "Open Dashboard",
        "category": "Claude Trace",
        "icon": "$(pulse)"
      }
    ],
    "keybindings": [
      {
        "command": "claudeTrace.openDashboard",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "configuration": {
      "title": "Claude Trace",
      "properties": {
        "claudeTrace.budgetPerSession": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Track a per-session USD budget for Claude Code sessions. Set to 0 to disable."
        },
        "claudeTrace.budgetPerDay": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Track today's combined Claude Code spend against this USD amount in the status bar, which turns amber at 80% and red when over. Set to 0 to disable."
        },
        "claudeTrace.webhookPort": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "Local port (127.0.0.1) for the pipeline webhook trigger listener. POST to http://127.0.0.1:<port>/?token=<token> to start a matching pipeline. Set to 0 to disable."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "package": "npm run compile && npx @vscode/vsce package",
    "publish": "npm run compile && npx @vscode/vsce publish",
    "publish:ovsx": "npx ovsx publish",
    "test:unit": "vitest run",
    "test:smoke": "npm run compile && node test/smoke/launch.mjs"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.25.2",
    "fast-check": "^3.23.2",
    "happy-dom": "^15.11.7",
    "memfs": "^4.17.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
